<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5" />
    </startup>


<appSettings>
        <!--<add key ="Mode" value ="Daily"/>-->
         <add key ="Mode" value ="Interval"/>
        <add key ="IntervalMinutes" value ="2"/>
        <add key ="ScheduledTime" value ="08:13"/>
    </appSettings>
	
	<connectionStrings>
		<add name="DBTinnitusTrio" connectionString="REPLACE_WITH_ENVIRONMENT_SPECIFIC_VALUE" providerName="System.Data.SqlClient"/>
	</connectionStrings>


</configuration>