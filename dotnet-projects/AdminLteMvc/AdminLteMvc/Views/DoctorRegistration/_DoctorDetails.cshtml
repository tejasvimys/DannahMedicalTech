@model List<AdminLteModels.DoctorRegistration>
    
<link href="~/Content/datatables/jquery.dataTables.min.css" rel="stylesheet" />
<script src="~/Content/datatables/jquery.dataTables.min.js"></script>
<style>
    .invisible {
        visibility: hidden;
    }
</style>
    
<script>
    $(document).ready(function() {
        $("#tblDoctorDetails").dataTable({
            'cell-border': true,
            "scrollX": true
        });
    });
   
</script>

               <table id="tblDoctorDetails" class="table table-striped table-bordered">
                   <thead>
                       <tr>
                           
                           <td>Doctor Code</td>
                           <td>Hospital Name</td>
                           <td>Name</td>
                           <td>City</td>
                           <td>State</td>
                           <td>Country</td>
                           <td>Phone</td>
                           <td>Mobile No</td>
                           <td>E-Mail</td>
                           <td>Serial Number</td>
                           <td>License Key</td>
                           <td>Is Active</td>
                           <td>Activation</td>
                           <td class="invisible">Doctor ID</td>
                   
                       </tr>
                   </thead>
                   <tbody>
                       @foreach (var item in Model)
                       {
                           <tr>
                               
                               <td>@item.DoctorCode</td>
                               <td>@item.HospitalName</td>
                               <td>@item.FirstName  @item.MiddleName  @item.LastName</td>
                               <td>@item.City</td>
                               <td>@item.State</td>
                               <td>@item.Country</td>
                               <td>@item.Phone</td>
                               <td>@item.Mobileno</td>
                               <td>@item.Email</td>
                               <td>@item.SerialNumber</td>
                               <td>@item.AuthenticationCode</td>
                               <td>@item.Isactive</td>
                               @if (item.Isactive)
                               {

                                   <td>
                                       <form action="DoctorStatusResults" method="post">
                                           @*<button type="button" id="btnSave" class="btn btn-block btn-danger btn-sm">De-Activate</button>*@
                                           @*<input type="submit" id="submit" class="btn btn-block btn-danger btn-sm" value="De-Activate" name="submit" />*@
                                           @Html.ActionLink("De-Activate", "DoctorStatusResults", "DoctorRegistration", new { id = item.DoctorId }, new { @class = "btn btn-block btn-danger btn-sm", @value = "De-Activate" })
                                       </form>
                                   </td>
                               }

                               else
                               {
                                   <td>
                                       <form action="DoctorStatusResults" method="post">
                                           @*<input type="submit" id="submit" class="btn btn-block btn-success btn-sm" value="Re-Activate" name="submit"/>*@
                                           @Html.ActionLink("Re-Activate", "ReactivateDoctorStatus", "DoctorRegistration", new { id = item.DoctorId }, new { @class = "btn btn-block btn-success btn-sm", @value = "Re-Activate" })
                                          
                                       </form>
                                   </td>
                               }
                               <td class="invisible">@item.DoctorId</td>
                           </tr>
                       }

                   </tbody>
               </table>
