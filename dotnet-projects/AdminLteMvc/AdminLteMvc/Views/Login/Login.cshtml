@model AdminLteModels.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">
    <title>Tinnitus Trio | Login</title>
    
    <!-- jQuery 2.2.3 -->
    <script src="~/Scripts/jquery-2.1.3.min.js"></script>
    <!-- Bootstrap 3.3.6 -->
    @Scripts.Render("~/bundles/bootstrap")
    @Styles.Render("~/Content/css")
    <!-- iCheck -->
    <script src="~/Scripts/AdminLTE/plugins/iCheck/icheck.min.js" type="text/javascript"></script>
    <link href="~/Content/AdminLTE/AdminLTE.min.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="~/Content/AdminLTE/Plugins/iCheck/square/blue.css">
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>

</head>
<body class="hold-transition login-page">
    <div class="login-box">
        <div class="login-logo">
            <a href="#"><b>TinnitusTrio</b>Admin Portal</a>
        </div>
        <!-- /.login-logo -->
    <div class="login-box-body">
        <p class="login-box-msg">Sign in to start your session</p>
        @*<form action="#" method="post">*@
        @using (Html.BeginForm("UserLogin", "Login", FormMethod.Post))
        {
            @Html.ValidationSummary()
            <div class="form-group has-feedback">
                
                @Html.TextBoxFor(model => model.Userid,new{@placeholder ="User ID", @class = "form-control" })
                @Html.ValidationMessageFor(model => model.Userid, "", new { @class = "text-danger" })

                <span class="glyphicon glyphicon-user form-control-feedback"></span>
            </div>
            <div class="form-group has-feedback">
                  
                @Html.TextBoxFor(model => model.Password,new{@placeholder ="Password", @class = "form-control", @type="password" })
                @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
                <span class="glyphicon glyphicon-lock form-control-feedback"></span>
            </div>
            <div class="row">
                <div class="col-xs-8">
                    <div class="checkbox icheck">
                        <label>
                            <input type="checkbox"> Remember Me
                        </label>
                    </div>
                </div>
                <!-- /.col -->
                <div class="col-xs-4">
                    <button type="submit" class="btn btn-primary btn-block btn-flat">Sign In</button>

                    <!-- /.col -->
                </div>
                  
                @*</form>*@
                <!-- /.social-auth-links -->
                <a href="#">I forgot my password</a><br>            
            </div>
                
        }
        <!-- /.login-box-body -->
    </div>
        </div>
    <!-- /.login-box -->
      <script>
        $(function () {
            $('input').iCheck({
                checkboxClass: 'icheckbox_square-blue',
                radioClass: 'iradio_square-blue',
                increaseArea: '20%' // optional
            });
        });
    </script>
</body>
</html>
