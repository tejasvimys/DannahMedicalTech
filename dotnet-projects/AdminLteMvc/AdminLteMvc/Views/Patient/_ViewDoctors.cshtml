@model List<AdminLteModels.DoctorRegistration>

    <link href="~/Content/datatables/jquery.dataTables.min.css" rel="stylesheet" />
    <script src="~/Content/datatables/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {
            $("#tblDoctorDetails").dataTable({
                'cell-border': true,
                "scrollX": true
            });
        });

    </script>

    <table id="tblDoctorDetails" class="table table-striped table-bordered">
        <thead>
            <tr>
                <td>Doctor ID</td>
                <td>Doctor Code</td>
                <td>Hospital Name</td>
                <td>Name</td>
                <td>City</td>
                <td>State</td>
                <td>Country</td>
                <td>Phone</td>
                <td>Mobile No</td>
                <td>E-Mail</td>
                <td>Is Active</td>              
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
{
    <tr onclick="location.href = '@(Url.Action("GetPatientInformation", "Patient", new { doctorCode = item.DoctorCode }))'">
        <td>@item.DoctorId</td>
        <td>@item.DoctorCode</td>
        <td>@item.HospitalName</td>
        <td>@item.FirstName  @item.MiddleName  @item.LastName</td>
        <td>@item.City</td>
        <td>@item.State</td>
        <td>@item.Country</td>
        <td>@item.Phone</td>
        <td>@item.Mobileno</td>
        <td>@item.Email</td>
        <td>@item.Isactive</td>
    </tr>
}

        </tbody>
    </table>
