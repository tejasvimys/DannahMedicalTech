@* 
 This partial controls the left menu of the AdminLTE dashboard and is called automatically by _AdminLteLayout
    This is where you can add, modify, or remove navigation options in your app
    TODO: This preserves the links as-is for the demo, which lead to broken pages!
    It's up to you to make sure these links either get deleted or lead somewhere REAL!
*@


@{
    Layout = null;
}
<aside class="main-sidebar">
    <!-- sidebar: style can be found in sidebar.less -->
    <section class="sidebar">
        <!-- Sidebar user panel -->
        <div class="user-panel">
            <div class="pull-left image">
                @*<img src="/Content/AdminLTE/img/user2-160x160.jpg" class="img-circle" alt="User Image" />*@
            </div>
            <div class="pull-left info">
                <p>@Session["AdminUser"].ToString()</p>
                <a href="#"><i class="fa fa-circle text-success"></i> Online</a>
            </div>
        </div>
       
        <!-- sidebar menu: : style can be found in sidebar.less -->
        <ul class="sidebar-menu">
            <li class="header">Tinnitus Trio Menu</li>
            <li class="active treeview">
                <a href="#">
                    <i class="fa fa-floppy-o"></i> <span>Doctor Management</span> <i class="fa fa-angle-left pull-right"></i>
                </a>
                <ul class="treeview-menu">
                    @*<li>@Html.ActionLink("Doctor Registration Online System", "OnlineDoctorReg", "DoctorRegistration")</li>*@
                    <li class="active">@Html.ActionLink("Doctor Registration Offline System", "Index", "DoctorRegistration")@*<a href="/DoctorRegistration/Index"><i class="fa fa-floppy-o"></i> Doctor Registration Offline System</a>*@</li>
                    <li>@Html.ActionLink("View Doctor Details", "ViewDoctorDetails", "DoctorRegistration")</li>
                </ul>
            </li>
            
            <li class="treeview">
                <a href="#">
                    <i class="fa fa-floppy-o"></i> <span>Patient Management</span> <i class="fa fa-angle-left pull-right"></i>
                </a>
                <ul class="treeview-menu">
                    <li>@Html.ActionLink("Patient Details", "ShowPatientDetails", "Patient")</li>
                </ul>
            </li>
            


            <li class="treeview">
                <a href="#">
                    <i class="fa fa-file-o"></i>
                    <span>License Management</span><i class="fa fa-angle-left pull-right"></i>
                  
                </a>
                <ul class="treeview-menu">
                    @*<li><a href="~/Subscription/Index"><i class="fa  fa-file-o"></i> Renew License</a></li>*@
                    <li>@Html.ActionLink("Renew License", "Index", "Subscription")</li>
                </ul>

                <ul class="treeview-menu">
                    @*<li><a href="~/Subscription/Index"><i class="fa  fa-file-o"></i> Renew License</a></li>*@
                    <li>@Html.ActionLink("Renewed License Details", "SubscriptionDetails", "Subscription")</li>
                </ul>
                
                <ul class="treeview-menu">
                    @*<li><a href="~/Subscription/Index"><i class="fa  fa-file-o"></i> Renew License</a></li>*@
                    <li>@Html.ActionLink("Re-Activate Doctor", "Index", "Subscription")</li>
                </ul>
                
                @*<ul class="treeview-menu">
                     <li><a href="~/Subscription/Index"><i class="fa  fa-file-o"></i> Renew License</a></li>
                    <li>@Html.ActionLink("Re-Activate Patient", "ViewDoctorDetails", "Patient")</li>
                </ul>*@

            </li>
            
          @{
              if (Session["AdminUser"].ToString() == "tejasvimys@gmail.com")
              {
                <li class="treeview">
                <a href="#">
                    <i class="fa fa-file-o"></i>
                    <span>User Management</span><i class="fa fa-angle-left pull-right"></i>

                </a>
                <ul class="treeview-menu">
                    @*<li><a href="~/Subscription/Index"><i class="fa  fa-file-o"></i> Renew License</a></li>*@
                    <li>@Html.ActionLink("Create New User", "User", "User")</li>
                </ul>
                </li>  
              }
          }
            
            
        </ul>
    </section>
    <!-- /.sidebar -->
</aside>