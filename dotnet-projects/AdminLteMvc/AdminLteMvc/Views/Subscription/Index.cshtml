@{
    // TODO: Consider setting Layout set automatially in _ViewStart.cshtml
    Layout = "~/Views/Shared/_AdminLteLayout.cshtml";


    // EXAMPLE:
    // Using the ViewBag on a page to set the title and sub-title
    // This will cause the _AdminLteLayout to include this value in the page title
    // And also set the top titles in the main content area of the page
    ViewBag.Title = "License Renewal for Offline System";
    //ViewBag.TitleSmall = "Version 2.0";

    // EXAMPLE:
    // Using the Breadcrumb class to create a dynamically generated breadcrumb on the page with
    // Titles, plus optional icon and URLs
    ViewBag.Breadcrumb = new Breadcrumb(new Crumb[] {
        new Crumb("License Renewal", "", "fa-floppy-o")
    });


}


 @model AdminLteModels.UserUniqueIdViewModel
<script src="~/Scripts/ModalDialog.js"></script>


<script type="text/javascript">
    $(document).ready(function () {

        $("#license").prop('disabled', 'disabled');
        $("#btnRenew").prop('disabled', 'disabled');

        //license save functionality
        $("#btnRenew").click(function() {
            
            waitingDialog.show('Please Wait!!');
            var doctorCode = $("#UniqueIdGeneration_DoctorCode").val();
            var license = $("#license option:selected").text();

            var jsonString = {};
            jsonString.DoctorCode = doctorCode;
            jsonString.Email = license;

            var dto = { 'objDoctorRegistration': jsonString };


            $.ajax({
                type: "POST",
                //url: "/Subscription/ActivateLicenses",
                url: '@Url.Action("ActivateLicenses", "Subscription")',
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                data: JSON.stringify(dto), // Check this call.
                success: function (data) {
                    waitingDialog.hide();
                    alert("License Renewed Successfully");
                    window.reload();
                },

                error: function (data) {
                    waitingDialog.hide();
                    alert(data.responseText);
                    $("#successMsg").hide();
                    $("#errorMsg").show();
                    $('#ajaxBusy').hide();
                }
            });


        });

        //check for the existance of the doctor
        $("#btnCheck").click(function () {

            var doctorCode = $("#UniqueIdGeneration_DoctorCode").val();
            var jsonString = {};
            jsonString.DoctorCode = doctorCode;
            var dto = { 'objDoctorRegistration': jsonString };
            waitingDialog.show('Please Wait!!');
            $.ajax({
                type: "POST",
                // url: "/Subscription/GetDoctorDetails",
                url: '@Url.Action("GetDoctorDetails", "Subscription")',
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                data: JSON.stringify(dto), // Check this call.
                success: function (data) {
                    var response = JSON.parse(data);
                    $("#UniqueIdGeneration_FirstName").html(response.FirstName + " " + response.LastName);
                    $("#UniqueIdGeneration_Email").html(response.Email);

                    $("#license").prop('disabled', '');
                    $("#btnRenew").prop('disabled', '');

                    waitingDialog.hide();
                },

                error: function (data) {
                    waitingDialog.hide();
                    alert(data.responseText);
                }
            });
        });

        $("#tblDoctorDetails").dataTable({
            'cell-border': true,
            "scrollX": true
        });
    });


</script>

<div class="row">
    <div class="col-md-6">
        <div class="box box-warning">
            <div class="box-body">
                <div class="form-inline form-group">
                    <label for="DoctorCode">Doctor Code</label>

                    @Html.TextBoxFor(m => m.UniqueIdGeneration.DoctorCode, new { @class = "form-control", @placeholder = "Enter Doctor Code", @maxlength = "3" })
                    <button type="button" id="btnCheck" class="btn btn-success">Check</button>

                </div>

                <div class="form-inline form-group">
                    <label for="DoctorName">Doctor Name</label>
                    @*@Html.LabelFor(m => m.UniqueIdGeneration.FirstName, new { @class = "form-control" })
                        @Html.LabelFor(m => m.UniqueIdGeneration.LastName, new { @class = "form-control" })*@
                    <label id="UniqueIdGeneration_FirstName" class="label-default"></label>
                </div>

                <div class="form-group">
                    <label for="DoctorName">Doctor E-Mail</label>
                    <label id="UniqueIdGeneration_Email" class="label-default"></label>
                </div>

                <div class="form-group">
                    <label for="clinicHospitalName">Number of Licenses to be issued</label>                
                    <select id="license" class="form-control" name="license">
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                        <option value="5">5</option>
                        <option value="6">6</option>
                        <option value="7">7</option>
                        <option value="8">8</option>
                        <option value="9">9</option>
                        <option value="10">10</option>
                        <option value="11">11</option>
                        <option value="12">12</option>
                        <option value="13">13</option>
                        <option value="14">14</option>
                        <option value="15">15</option>
                        <option value="16">16</option>
                        <option value="17">17</option>
                        <option value="18">18</option>
                        <option value="19">19</option>
                        <option value="20">20</option>
                        <option value="20">21</option>
                        <option value="20">22</option>
                        <option value="20">23</option>
                        <option value="20">24</option>
                        <option value="20">25</option>
                    </select>
                </div>

                <div class="form-group">
                    <button type="button" id="btnRenew" class="btn btn-block btn-success btn-lg">Renew Licenses</button>
                    <button type="button" id="btnReset" class="btn btn-block btn-primary btn-lg">Reset Data</button>
                </div>
            </div>
        </div>
    </div>
    
    
    <div class="col-md-6">
        <div class="box box-warning">
            <div class="box-body">
                <table id="tblDoctorDetails" class="table table-striped table-bordered">
                    <thead>
                        <tr>

                            <td>Request ID</td>
                            <td>Doctor Code</td>
                            <td>Requested License Quantity</td>
                            <td>Request Active Status</td>
                            <td>Requested Date</td>  
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OfllineLicensesRequest)
                        {
                            <tr>
                                <td>@item.RequestId</td>
                                <td>@item.DoctorCode</td>
                                <td>@item.LicenseQuantity</td>
                                <td>@item.RequestActiveStatus</td>
                                <td>@item.RequestDate</td>
                            </tr>
                        }
                       
                    </tbody>
                    </table>
            </div>
        </div>
    </div>
    

</div>



    <div id="myModal" class="modal modal-primary fade">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title">User Re-Authentication</h4>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label for="DoctorCode">Enter Your Password</label>
                    @Html.TextBoxFor(m => m.GetUser.Password, new { @class = "form-control", @placeholder = "Enter Password Here" })
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline pull-left" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-outline">Authenticate</button>
            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!-- /.modal-dialog -->
</div>
    <!-- /.modal -->
